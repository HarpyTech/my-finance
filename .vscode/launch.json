{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "FastAPI: Debug (uvicorn)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "app.main:app",
        "--host", "0.0.0.0",
        "--port", "8000",
        "--reload"
      ],
      "python": "${workspaceFolder}/.venv311/Scripts/python.exe",
      "envFile": "${workspaceFolder}/.env",
      "cwd": "${workspaceFolder}",
      "jinja": true,
      "justMyCode": false
    }
  ]
}
