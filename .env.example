# Application Configuration
PROJECT_NAME=My Finance App
BUILD_VERSION=dev

# API Configuration
API_V1_STR=/api/v1

# Security Settings - CHANGE THESE IN PRODUCTION!
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars
JWT_SECRET=your-jwt-signing-secret-change-this-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
ENVIRONMENT=development
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# Google OAuth2 (Authorization Code Flow)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# Optional frontend redirect and restrictions
FRONTEND_BASE_URL=
OAUTH_SUCCESS_REDIRECT=/dashboard
OAUTH_FAILURE_REDIRECT=/login
GOOGLE_ALLOWED_DOMAINS=example.com,harpytechco.in
DEFAULT_USER_ROLE=ROLE_USER
ADMIN_EMAILS=admin@harpytechco.in

# Default User Credentials
DEFAULT_LOGIN_PASSWORD=ChangeMe123!

# MongoDB Configuration
# IMPORTANT: If your username or password contains special characters (@ # $ % ^ & : / ? [ ]),
# you MUST URL-encode them. Use Python's urllib.parse.quote_plus() or encode manually:
#   @ becomes %40
#   # becomes %23
#   $ becomes %24
#   % becomes %25
#   ^ becomes %5E
#   & becomes %26
#   : becomes %3A
#   / becomes %2F
#
# Examples:
#   Local: mongodb://localhost:27017
#   Atlas: mongodb+srv://username:encoded-password@cluster.mongodb.net/?retryWrites=true&w=majority
#   With special chars: mongodb+srv://user:Pass%40word%231@cluster.mongodb.net/
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=my_finance

# Gemini extraction
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# CORS Origins - Optional, has defaults in code
# Accepts either a comma-separated string or a JSON array.
# Production example:
# CORS_ORIGINS=https://finance.example.com,https://api.finance.example.com
# JSON example:
# CORS_ORIGINS=["https://finance.example.com","https://api.finance.example.com"]
